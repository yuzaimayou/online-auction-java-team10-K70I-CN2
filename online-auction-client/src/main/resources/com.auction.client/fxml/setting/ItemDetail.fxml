<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="1200.0" spacing="20.0" styleClass="main-content-wrapper" stylesheets="@../../css/ItemDetail.css" HBox.hgrow="ALWAYS" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.setting.ItemDetailPageController">
    <padding>
        <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0" />

    <HBox prefHeight="608.0" prefWidth="1136.0" spacing="25.0" VBox.vgrow="ALWAYS">
        <VBox spacing="20.0" styleClass="detail-card" HBox.hgrow="ALWAYS">
           <Hyperlink fx:id="backLink" onAction="#handleBack" styleClass="back-link" text="← Back to My Auctions" />
            <Label styleClass="section-title" text="Product Information" />

            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                <VBox alignment="TOP_CENTER">
                     <ImageView fx:id="productImage" fitHeight="200.0" fitWidth="200.0" preserveRatio="true" />
                </VBox>
            <VBox prefHeight="200.0" prefWidth="100.0">
               <children>
                       <Label fx:id="nameLabel" styleClass="info-value-title" text="Nước Hoa Nữ Versace Crystal Noir" wrapText="true" />
      
                      <GridPane hgap="20.0" vgap="15.0">
                          <columnConstraints>
                              <ColumnConstraints minWidth="120" prefWidth="140" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                          </columnConstraints>
      
                          <Label styleClass="info-label" text="Category" GridPane.rowIndex="1" />
                          <Label fx:id="categoryLabel" styleClass="info-value" text="Perfume" GridPane.columnIndex="1" GridPane.rowIndex="1" />
      
                          <Label styleClass="info-label" text="⏱ Start Price" GridPane.rowIndex="2" />
                          <Label fx:id="startPriceLabel" styleClass="info-value-bold" text="₫300,000" GridPane.columnIndex="1" GridPane.rowIndex="2" />
      
                          <Label styleClass="info-label" text="↕ Bid Increment" GridPane.rowIndex="3" />
                          <Label fx:id="incrementLabel" styleClass="info-value-bold" text="₫20,000" GridPane.columnIndex="1" GridPane.rowIndex="3" />
      
                          <Label styleClass="info-label" text="🕒 Start Time" GridPane.rowIndex="4" />
                          <Label fx:id="startTimeLabel" styleClass="info-value" text="18/05/2026 10:00 AM" GridPane.columnIndex="1" GridPane.rowIndex="4" />
      
                          <Label styleClass="info-label" text="🏁 End Time" GridPane.rowIndex="5" />
                          <Label fx:id="endTimeLabel" styleClass="info-value" text="20/05/2026 10:37 AM" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                          <rowConstraints>
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" />
                              <RowConstraints vgrow="ALWAYS" />
                          </rowConstraints>
                      </GridPane>
      
                       <Label styleClass="info-label" text="Description" />
                       <Label fx:id="descriptionLabel" styleClass="info-value-desc" text="Hương thơm quyến rũ, sang trọng và đầy bí ẩn. Versace Crystal Noir Parfum là sự kết hợp hoàn hảo giữa nét thanh lịch hiện đại và sự gợi cảm vượt thời gian..." wrapText="true" />
               </children>
            </VBox>
            </HBox>
        </VBox>

        <VBox minWidth="400.0" prefWidth="480.0" spacing="20.0">
            <VBox fx:id="historySection" prefHeight="480.0" prefWidth="449.0" spacing="15.0" styleClass="detail-card" VBox.vgrow="ALWAYS">
                <Label styleClass="section-title-small" text="Bidding History" />
                <TableView fx:id="historyTable" styleClass="mini-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colBidder" prefWidth="120.0" text="Bidder" />
                        <TableColumn fx:id="colAmount" prefWidth="130.0" text="Bid Amount" />
                        <TableColumn fx:id="colTime" prefWidth="160.0" text="Bid Time" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <HBox spacing="12.0">
                <VBox alignment="CENTER" spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="summary-title" text="Highest Bid" />
                    <Label styleClass="summary-price" text="₫2,850,000" />
                    <Label styleClass="summary-sub" text="by admin" />
                </VBox>

                <VBox alignment="CENTER" spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="summary-title" text="Your Bid" />
                    <Label styleClass="summary-price-blue" text="₫2,850,000" />
                    <Label styleClass="summary-sub-blue" text="Winning" />
                </VBox>

                <VBox alignment="CENTER" spacing="8.0" styleClass="summary-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="summary-title" text="Auction Ended" />
                    <Label style="-fx-font-size: 22px;" text="🔨" />
                    <Label styleClass="summary-sub" text="20/05/2026 10:37 AM" />
                </VBox>
            </HBox>
        </VBox>
    </HBox>
</VBox>
