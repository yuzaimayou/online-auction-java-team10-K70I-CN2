<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="1000.0" spacing="25.0"
      HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" minHeight="-Infinity" maxHeight="Infinity"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.setting.DepositController"
      styleClass="content-card"
      stylesheets="@../../css/DepositPage.css">

    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Button onAction="#handleBackToWallet" styleClass="back-btn" text="←  Quay lại"/>
    </HBox>

    <VBox spacing="6.0">
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="💰" styleClass="title-icon"/>
            <Label text="Nạp tiền vào tài khoản" styleClass="main-title" />
        </HBox>
        <Label text="Chọn số tiền và phương thức thanh toán phù hợp." styleClass="sub-description"/>
    </VBox>

    <Separator styleClass="custom-separator"/>

    <VBox spacing="15.0">
        <Label text="1. Chọn số tiền nạp" styleClass="step-label"/>
        <HBox spacing="12.0">
            <fx:define>
                <ToggleGroup fx:id="amountGroup"/>
            </fx:define>
            <ToggleButton fx:id="btn50" text="\$50" styleClass="amount-btn" toggleGroup="$amountGroup" onAction="#handleAmountSelection"/>
            <ToggleButton fx:id="btn100" text="\$100" styleClass="amount-btn" toggleGroup="$amountGroup" onAction="#handleAmountSelection"/>
            <ToggleButton fx:id="btn200" text="\$200" styleClass="amount-btn" toggleGroup="$amountGroup" onAction="#handleAmountSelection"/>
            <ToggleButton fx:id="btn500" text="\$500" styleClass="amount-btn" toggleGroup="$amountGroup" onAction="#handleAmountSelection"/>
            <ToggleButton fx:id="btn1000" text="\$1000" styleClass="amount-btn" toggleGroup="$amountGroup" onAction="#handleAmountSelection"/>
        </HBox>

        <TextField fx:id="amountField" promptText="Hoặc nhập số tiền khác muốn nạp" styleClass="input-amount-field" prefHeight="45.0"/>
    </VBox>

    <VBox spacing="15.0">
        <Label text="2. Phương thức thanh toán" styleClass="step-label"/>
        <VBox spacing="12.0">
            <fx:define>
                <ToggleGroup fx:id="paymentGroup"/>
            </fx:define>

            <HBox spacing="15.0" styleClass="payment-card" alignment="CENTER_LEFT">
                <Label text="📱" styleClass="payment-icon-emoji"/>
                <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                    <Label text="Ví điện tử ZaloPay" styleClass="payment-name"/>
                    <Label text="Thanh toán nhanh qua ứng dụng ZaloPay" styleClass="payment-desc"/>
                </VBox>
                <RadioButton fx:id="radioZaloPay" toggleGroup="$paymentGroup"/>
            </HBox>

            <HBox spacing="15.0" styleClass="payment-card" alignment="CENTER_LEFT">
                <Label text="🏦" styleClass="payment-icon-emoji"/>
                <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                    <Label text="Chuyển khoản ngân hàng" styleClass="payment-name"/>
                    <Label text="Chuyển khoản qua tài khoản ngân hàng nội địa (Internet Banking)" styleClass="payment-desc"/>
                </VBox>
                <RadioButton fx:id="radioBank" toggleGroup="$paymentGroup"/>
            </HBox>
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT">
        <Button text="Xác nhận nạp tiền" onAction="#handleConfirmDeposit" styleClass="btn-confirm-main"/>
    </HBox>
</VBox>