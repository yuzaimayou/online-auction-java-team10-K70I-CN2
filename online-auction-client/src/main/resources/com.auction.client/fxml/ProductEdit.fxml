<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="850.0" prefWidth="1440.0"
      styleClass="root-container"
      stylesheets="@../css/ProductEdit.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.setting.ProductEditController">

    <fx:include source="NavBar.fxml" />

    <StackPane VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="40.0" top="40.0" />
        </padding>

        <VBox alignment="CENTER" maxHeight="850.0" maxWidth="1000.0" styleClass="form-card">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <content>
                    <VBox spacing="20.0">
                        <padding>
                            <Insets bottom="50.0" left="50.0" right="50.0" top="30.0" />
                        </padding>

                        <StackPane>
                            <VBox alignment="CENTER_LEFT" StackPane.alignment="CENTER_LEFT">
                                <Label alignment="CENTER" contentDisplay="CENTER" styleClass="form-card-header" text="Edit Auction Item" textAlignment="CENTER" />
                                <Label fx:id="lblMessage" text="" textFill="RED">
                                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                                </Label>
                            </VBox>

                            <Button fx:id="btnClose" onAction="#handleClose" prefHeight="40.0" prefWidth="40.0" styleClass="btn-close" text="✕" StackPane.alignment="CENTER_RIGHT" />
                        </StackPane>

                        <HBox spacing="40.0">
                            <VBox spacing="15.0">
                                <StackPane styleClass="image-main-wrapper">
                                    <ImageView fitHeight="200.0" fitWidth="320.0" pickOnBounds="true" preserveRatio="false">
                                        <image>
                                            <Image url="@../assets/macbook.jpg" />
                                        </image>
                                    </ImageView>
                                </StackPane>

                                <HBox fx:id="imageContainer" alignment="CENTER_LEFT" spacing="12.0">
                                    <StackPane styleClass="img-thumbnail, active-thumbnail">
                                        <ImageView fitHeight="60.0" fitWidth="80.0" pickOnBounds="true">
                                            <image><Image url="@../assets/macbook.jpg" /></image>
                                        </ImageView>
                                    </StackPane>

                                    <StackPane styleClass="img-thumbnail">
                                        <ImageView fitHeight="60.0" fitWidth="80.0" pickOnBounds="true">
                                            <image><Image url="@../assets/macbook.jpg" /></image>
                                        </ImageView>
                                    </StackPane>

                                    <VBox alignment="CENTER" prefHeight="64.0" prefWidth="84.0" styleClass="btn-add-photo-small">
                                        <Label style="-fx-font-size: 20px; -fx-text-fill: #3B82F6; -fx-font-weight: bold;" text="+" />
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #3B82F6;" text="Add Photo" />
                                    </VBox>
                                </HBox>
                            </VBox>

                            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="item-title-large" text="Macbook Pro 13inch" />
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label styleClass="badge-upcoming" text="Upcoming Auction" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 16px;" text="🕒" />
                                    <Label styleClass="info-text-bold" text="Auction starts in: 2d 16h 45m" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 16px;" text="🏷" />
                                    <Label styleClass="info-text-bold" text="Electronics" />
                                </HBox>
                                <Label styleClass="alert-bar" text="!  You just can edit this item before the auction starts" wrapText="true" />
                            </VBox>
                        </HBox>

                        <VBox spacing="10.0">
                            <Label styleClass="field-label" text="Product Name " />
                            <TextField fx:id="txtProductName" prefHeight="50.0" styleClass="input-field" text="Macbook Pro 13inch" />
                        </VBox>


                        <VBox spacing="15.0">
                            <Label styleClass="field-label" text="Category"/>
                            <HBox alignment="CENTER" spacing="35.0">
                                <fx:define>
                                    <ToggleGroup fx:id="categoryGroup"/>
                                </fx:define>

                                <VBox alignment="CENTER" spacing="10.0">
                                    <ToggleButton fx:id="btnFashion" userData="Fashion" styleClass="category-btn"
                                                  toggleGroup="$categoryGroup">
                                        <graphic>
                                            <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                                                <image>
                                                    <Image url="@../assets/fashion_icon.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </ToggleButton>
                                    <Label styleClass="category-text" text="Fashion"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <ToggleButton fx:id="btnElectronics" userData="Electronics"
                                                  styleClass="category-btn"
                                                  toggleGroup="$categoryGroup">
                                        <graphic>
                                            <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                                                <image>
                                                    <Image url="@../assets/electronics_icon.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </ToggleButton>
                                    <Label styleClass="category-text" text="Electronics"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <ToggleButton fx:id="btnHome" userData="Home" styleClass="category-btn"
                                                  toggleGroup="$categoryGroup">
                                        <graphic>
                                            <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                                                <image>
                                                    <Image url="@../assets/home_icon.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </ToggleButton>
                                    <Label styleClass="category-text" text="Home &amp; Garden"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <ToggleButton fx:id="btnArt" userData="Art" styleClass="category-btn"
                                                  toggleGroup="$categoryGroup">
                                        <graphic>
                                            <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                                                <image>
                                                    <Image url="@../assets/art_icon.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </ToggleButton>
                                    <Label styleClass="category-text" text="Art"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <ToggleButton fx:id="btnBook" userData="Book" styleClass="category-btn"
                                                  toggleGroup="$categoryGroup">
                                        <graphic>
                                            <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                                                <image>
                                                    <Image url="@../assets/book_icon.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </ToggleButton>
                                    <Label styleClass="category-text" text="Book"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <ToggleButton fx:id="btnJewelry" userData="Jewelry" styleClass="category-btn"
                                                  toggleGroup="$categoryGroup">
                                        <graphic>
                                            <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                                                <image>
                                                    <Image url="@../assets/jewelry_icon.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </ToggleButton>
                                    <Label styleClass="category-text" text="Jewelry"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <ToggleButton fx:id="btnSports" userData="Sports" styleClass="category-btn"
                                                  toggleGroup="$categoryGroup">
                                        <graphic>
                                            <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                                                <image>
                                                    <Image url="@../assets/sports_icon.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </ToggleButton>
                                    <Label styleClass="category-text" text="Sports"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="10.0">
                            <Label styleClass="field-label" text="Description" />
                                <TextArea fx:id="txtProductDesc" prefHeight="120.0"
                                          promptText="Enter detailed product description..."
                                          styleClass="input-field, text-area" />
                        </VBox>

                        <VBox spacing="25.0">
                            <HBox spacing="30.0">
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Starting Price" />
                                    <TextField fx:id="txtInitPrice" prefHeight="50.0" promptText="100" styleClass="input-field" />
                                </VBox>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Bid Increment" />
                                    <TextField fx:id="txtBidStep" prefHeight="50.0" promptText="20" styleClass="input-field" />
                                </VBox>
                            </HBox>

                            <HBox spacing="30.0">
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text="Start Time " />
                                    <HBox spacing="10.0">
                                        <DatePicker fx:id="startDateP" maxWidth="Infinity" prefHeight="60.0"
                                                    promptText="21/04/2026"
                                                    styleClass="date-picker"
                                                    HBox.hgrow="ALWAYS" />
                                        <ComboBox fx:id="cbStartTime" prefHeight="60.0" prefWidth="130.0" promptText="10:00 PM" styleClass="time-picker" />
                                    </HBox>
                                </VBox>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="field-label" text=" End Time " />
                                    <HBox spacing="10.0">
                                        <DatePicker fx:id="endDateP" maxWidth="Infinity" prefHeight="60.0" promptText="28/04/2026" styleClass="date-picker" HBox.hgrow="ALWAYS" />
                                        <ComboBox fx:id="cbEndTime" prefHeight="60.0" prefWidth="130.0" promptText="10:00 PM" styleClass="time-picker" />
                                    </HBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <VBox.margin><Insets top="20.0" /></VBox.margin>
                            <Button prefHeight="60.0" styleClass="btn-cancel-modern" text="Cancel" />
                            <Button prefHeight="60.0" styleClass="btn-save-modern" text="Save Changes" />
                        </HBox>

                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </StackPane>
</VBox>
