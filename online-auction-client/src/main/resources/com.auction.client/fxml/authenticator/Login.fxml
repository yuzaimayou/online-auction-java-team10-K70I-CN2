<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<HBox fx:id="rootNode" alignment="CENTER"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.auth.LoginController">
    <stylesheets>
        <URL value="@../../css/AuthPage.css"/>
    </stylesheets>

    <StackPane HBox.hgrow="ALWAYS" styleClass="image-container, login-image-bg"
               minWidth="0" prefWidth="400.0">
    </StackPane>

    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff;"
          minWidth="380.0" prefWidth="400.0">

        <padding>
            <Insets bottom="20.0" left="40.0" right="40.0" top="20.0"/>
        </padding>

        <VBox alignment="CENTER" maxWidth="400.0" spacing="25.0" VBox.vgrow="SOMETIMES">
            <Label fx:id="lblMessage" wrapText="true" textAlignment="CENTER"/>
            <Label id="main-title" text="Sign in" style="-fx-font-size: 2.5em; -fx-font-weight: bold;"/>

            <VBox spacing="15.0" fillWidth="true">
                <VBox spacing="8.0">
                    <Label styleClass="title" text="Username"/>
                    <TextField fx:id="txtUsername" styleClass="textBox" prefHeight="45.0"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label styleClass="title" text="Password"/>
                    <PasswordField fx:id="txtPassword" styleClass="textBox" prefHeight="45.0"/>
                </VBox>
            </VBox>

            <Button onAction="#handleLogin" defaultButton="true"
                    styleClass="submitButton" text="Sign in"
                    maxWidth="Infinity" prefHeight="50.0"/>

            <HBox alignment="CENTER" spacing="8.0">
                <Label style="-fx-font-size: 14;" text="New to Auction?"/>
                <Button onAction="#handleSwitchToRegister" styleClass="switchButton" text="Create an account"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>