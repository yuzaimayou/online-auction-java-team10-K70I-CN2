<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<HBox fx:id="rootNode" prefHeight="1024.0" prefWidth="1440.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.user.LoginController">
    <stylesheets>
        <URL value="@../../css/AuthPage.css"/>
    </stylesheets>

    <StackPane HBox.hgrow="ALWAYS" styleClass="image-container, login-image-bg">
    </StackPane>

    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" minWidth="500.0" style="-fx-background-color: #ffffff;">
        <padding>
            <Insets bottom="50.0" left="100.0" right="100.0" top="50.0"/>
        </padding>

        <VBox alignment="CENTER" maxWidth="450.0" spacing="30.0">
            <Label fx:id="lblMessage" wrapText="true" textAlignment="CENTER"/>
            <Label id="main-title" text="Sign in"/>

            <VBox spacing="15.0">
                <VBox spacing="8.0">
                    <Label styleClass="title" text="Username"/>
                    <TextField fx:id="txtUsername" styleClass="textBox"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label styleClass="title" text="Password"/>
                    <PasswordField fx:id="txtPassword" styleClass="textBox"/>
                </VBox>
            </VBox>

            <Button onAction="#handleLogin" defaultButton="true" styleClass="submitButton" text="Sign in"/>

            <HBox alignment="CENTER" spacing="8.0">
                <Label style="-fx-font-size: 16;" text="New to Auction?"/>
                <Button onAction="#handleSwitchToRegister" styleClass="switchButton" text="Create an account"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>