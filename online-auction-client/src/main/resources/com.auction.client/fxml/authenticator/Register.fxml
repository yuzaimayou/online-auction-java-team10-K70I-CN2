<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<HBox fx:id="rootNode" alignment="CENTER"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.auth.RegisterController">
    <stylesheets>
        <URL value="@../../css/AuthPage.css"/>
    </stylesheets>

    <StackPane HBox.hgrow="ALWAYS" styleClass="image-container, register-image-bg"
               minWidth="0" prefWidth="400.0">
    </StackPane>

    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff;"
          minWidth="380.0" prefWidth="400.0">

        <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
        </padding>

        <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" VBox.vgrow="SOMETIMES">
            <Label fx:id="lblMessage" wrapText="true" textAlignment="CENTER"/>
            <Label id="main-title" text="Sign up" style="-fx-font-size: 2.2em; -fx-font-weight: bold;"/>

            <VBox spacing="12.0" fillWidth="true">
                <VBox spacing="5.0">
                    <Label styleClass="title" text="Email address"/>
                    <TextField fx:id="txtEmail" styleClass="textBox" prefHeight="40.0"/>
                </VBox>

                <VBox spacing="5.0">
                    <Label styleClass="title" text="Username"/>
                    <TextField fx:id="txtUsername" styleClass="textBox" prefHeight="40.0"/>
                </VBox>

                <VBox spacing="5.0">
                    <Label styleClass="title" text="Password"/>
                    <PasswordField fx:id="txtPassword" styleClass="textBox" prefHeight="40.0"/>
                </VBox>

                <VBox spacing="5.0">
                    <Label styleClass="title" text="Confirm password"/>
                    <PasswordField fx:id="txtConfirmPassword" styleClass="textBox" prefHeight="40.0"/>
                </VBox>
            </VBox>

            <Button id="registerSubmit" mnemonicParsing="false" defaultButton="true"
                    onAction="#handleRegister" styleClass="submitButton"
                    text="Creating account &gt;" maxWidth="Infinity" prefHeight="45.0">
                <VBox.margin>
                    <Insets top="10.0"/>
                </VBox.margin>
            </Button>

            <HBox alignment="CENTER" spacing="8.0">
                <Label style="-fx-font-size: 14;" text="Already have account?"/>
                <Button onAction="#handleSwitchToLogin" styleClass="switchButton" text="Sign in"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>