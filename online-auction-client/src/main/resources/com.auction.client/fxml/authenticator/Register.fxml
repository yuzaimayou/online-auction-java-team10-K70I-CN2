<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox id="auth-page" alignment="CENTER" prefHeight="1024.0" prefWidth="720.0" spacing="30.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.user.RegisterController">
    <stylesheets>
        <URL value="@../../css/AuthPage.css" />
    </stylesheets>
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <Label fx:id="lblMessage" text="" />
    <Label id="main-title" text="Sign up">

    </Label>

    <VBox maxWidth="463.0" prefWidth="463.0" spacing="20.0">

        <VBox spacing="8.0">
            <Label styleClass="title" text="Email address">
            </Label>
            <TextField fx:id="txtEmail" prefHeight="43.0" promptText="" styleClass="textBox" />
        </VBox>

        <VBox spacing="8.0">
            <Label styleClass="title" text="Username">
            </Label>
            <TextField fx:id="txtUsername" prefHeight="43.0" promptText="" styleClass="textBox" />
        </VBox>

        <VBox spacing="8.0">
            <Label styleClass="title" text="Password">

            </Label>
            <PasswordField fx:id="txtPassword" prefHeight="43.0" promptText="" styleClass="textBox" />
        </VBox>

        <VBox spacing="8.0">
            <Label styleClass="title" text="Confirm password">

            </Label>
            <PasswordField fx:id="txtConfirmPassword" prefHeight="43.0" promptText="" styleClass="textBox" />
        </VBox>


        <Button id="registerSubmit" mnemonicParsing="false" onAction="#handleRegister" prefHeight="58.0" prefWidth="463.0" styleClass="submitButton" text="Creating account &gt;">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>

        <HBox alignment="CENTER" spacing="5.0">
            <VBox.margin>
                <Insets top="15.0" />
            </VBox.margin>
            <Label style="-fx-font-size: 16;" text="Already have account?">

            </Label>
            <Button onAction="#handleSwitchToLogin" styleClass="switchButton" text="Sign in">
            </Button>
        </HBox>

    </VBox>
</VBox>
