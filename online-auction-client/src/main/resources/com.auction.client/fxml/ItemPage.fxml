<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.client.controller.auction.ItemPageController">
    <VBox styleClass="main-container">
        <fx:include fx:id="navBar" source="NavBar.fxml"/>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" stylesheets="@../css/ItemPage.css">
            <HBox alignment="TOP_CENTER" spacing="30" styleClass="content-wrapper">

                <VBox fx:id="leftColumn" spacing="25" HBox.hgrow="ALWAYS" maxWidth="750">
                    <StackPane fx:id="mainImageContainer" minHeight="250" prefHeight="450" styleClass="main-image-container">
                        <ImageView fx:id="itemImage" pickOnBounds="true" StackPane.alignment="CENTER"/>
                    </StackPane>

                    <HBox fx:id="thumbnailContainer" alignment="CENTER_LEFT" spacing="15"></HBox>
                    <Label fx:id="itemNameLabel" styleClass="item-title" text="NAME ITEM" wrapText="true"/>

                    <VBox spacing="17.0" styleClass="chart-container-modern" VBox.vgrow="NEVER" maxWidth="Infinity">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane styleClass="trend-icon-bg">
                                <Region styleClass="trend-icon"/>
                            </StackPane>
                            <Label styleClass="chart-title" text="Price Trend"/>
                        </HBox>

                        <Separator/>

                        <AreaChart fx:id="bidPriceChart" prefHeight="320" minHeight="320" maxWidth="Infinity"
                                   createSymbols="true" legendVisible="false"
                                   animated="false" styleClass="modern-area-chart" VBox.vgrow="ALWAYS">
                            <xAxis>
                                <CategoryAxis fx:id="bidTimeAxis" label="Time" animated="false" tickMarkVisible="false"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="bidPriceAxis" label="Price ($)" autoRanging="true" animated="false"
                                            tickMarkVisible="false" minorTickVisible="false"/>
                            </yAxis>
                        </AreaChart>
                    </VBox>

                    <VBox spacing="17.0" styleClass="description-container" VBox.vgrow="NEVER" maxWidth="Infinity">
                        <Label styleClass="sub-section-title" text="Description"/>
                        <Separator/>
                        <Label fx:id="itemDesLabel" alignment="TOP_LEFT" maxWidth="Infinity"
                               styleClass="description-body" text="description item" wrapText="true"/>
                    </VBox>
                </VBox>

                <VBox minWidth="330" prefWidth="380" maxWidth="380" spacing="20">

                    <VBox styleClass="auction-info-card" >
                        <VBox alignment="CENTER" spacing="5">
                            <Label styleClass="time-left-title" text="Time Left:"/>
                            <HBox alignment="CENTER" spacing="15" styleClass="timer-container">
                                <VBox alignment="CENTER">
                                    <Label fx:id="daysLabel" styleClass="timer-num" text="00"/>
                                    <Label styleClass="timer-unit" text="DAYS"/>
                                </VBox>
                                <VBox alignment="CENTER">
                                    <Label fx:id="hoursLabel" styleClass="timer-num" text="00"/>
                                    <Label styleClass="timer-unit" text="HOURS"/>
                                </VBox>
                                <VBox alignment="CENTER">
                                    <Label fx:id="minsLabel" styleClass="timer-num" text="00"/>
                                    <Label styleClass="timer-unit" text="MINUTES"/>
                                </VBox>
                                <VBox alignment="CENTER">
                                    <Label fx:id="secsLabel" styleClass="timer-num" text="00"/>
                                    <Label styleClass="timer-unit" text="SECONDS"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <Separator/>

                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <Circle fill="#2D55FF" radius="12"/>
                            <Label fx:id="sellerLabel" styleClass="seller-label" text="Seller: ..."/>
                        </HBox>

                        <VBox spacing="15.0">
                            <HBox alignment="CENTER_LEFT">
                                <Label styleClass="current-bid-title" text="Current Bid:"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="currentPriceLabel" styleClass="current-bid" text="000"/>
                            </HBox>

                            <Separator/>

                            <GridPane hgap="10" vgap="10">
                                <Label styleClass="text-info" text="Starting Price:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="startPriceLabel" styleClass="info-value-bold" text="..." GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label styleClass="text-info" text="Increment Amount:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="bidStepLabel" styleClass="info-value-bold" text="..." GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label styleClass="text-info" text="Starts at:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Label fx:id="startTimeLabel" styleClass="info-value-bold" text="..." GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label styleClass="text-info" text="Ends at:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <Label fx:id="endTimeLabel" styleClass="info-value-bold" text="..." GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                <columnConstraints>
                                    <ColumnConstraints minWidth="130"/>
                                    <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
                                </columnConstraints>
                            </GridPane>
                        </VBox>

                        <VBox spacing="10">
                            <VBox fx:id="bidControlsContainer" spacing="10">
                                <Label fx:id="minimumBidLabel" styleClass="bid-title" text="Your last bid ( min next: $ 0 )"/>
                                <HBox spacing="10">
                                    <Button fx:id="btnSuggestStep1" maxWidth="Infinity" styleClass="bid-suggest-btn" text="..." HBox.hgrow="ALWAYS" onAction="#handleSuggestStep1"/>
                                    <Button fx:id="btnSuggestStep2" maxWidth="Infinity" styleClass="bid-suggest-btn" text="..." HBox.hgrow="ALWAYS" onAction="#handleSuggestStep2"/>
                                </HBox>

                                <TextField fx:id="bidAmountField" promptText="Enter bid " styleClass="bid-input"/>
                                <Button fx:id="submitBid" maxWidth="Infinity" onAction="#bidHandle" styleClass="btn-place-bid" text="Place Bid" />

                                <Button fx:id="btnAutoBidToggle" maxWidth="Infinity" onAction="#toggleAutoBidForm" styleClass="btn-auto-bid" text="Auto Bid"/>
                            </VBox>

                            <StackPane fx:id="statusOverlay" managed="false" visible="false">
                                <Label fx:id="statusMessageLabel" styleClass="status-message-label" wrapText="true" alignment="CENTER"/>
                            </StackPane>

                            <VBox fx:id="autoBidForm" managed="false" spacing="15" styleClass="auto-bid-panel" visible="false">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <ImageView fitHeight="30" fitWidth="30">
                                        <Image url="@../assets/robot_icon.png"/>
                                    </ImageView>
                                    <Label styleClass="auto-bid-header" text="Auto Bid"/>
                                </HBox>
                                <VBox spacing="5">
                                    <Label styleClass="input-label" text="Max Bid"/>
                                    <TextField fx:id="maxBidField" promptText="Nhập giá tối đa" styleClass="auto-bid-text-field"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label styleClass="input-label" text="Bid Amount"/>
                                    <TextField fx:id="autoBidStepField" promptText="Nhập bước nhảy" styleClass="auto-bid-text-field"/>
                                </VBox>
                                <Label styleClass="auto-bid-info" text="Hệ thống sẽ tự động đấu giá đến tối đa bạn đặt" wrapText="true"/>
                                <Button maxWidth="Infinity" onAction="#startAutoBid" styleClass="btn-place-bid" text="Start"/>
                            </VBox>

                            <VBox fx:id="autoBidActiveStatus" managed="false" spacing="10" visible="false">
                                <VBox styleClass="auto-bid-active-panel">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <ImageView fitHeight="30" fitWidth="30">
                                            <Image url="@../assets/robot_icon.png"/>
                                        </ImageView>
                                        <Label styleClass="auto-bid-header" text="Auto Bid đang hoạt động"/>
                                    </HBox>
                                    <Label fx:id="userCurrentBidLabel" styleClass="user-current-bid" text="Your current bid: 0 VNĐ"/>
                                    <Label styleClass="auto-bid-info" text="! Hệ thống sẽ tự động đấu giá đến tối đa bạn đặt"/>
                                </VBox>
                                <Button maxWidth="Infinity" onAction="#stopAutoBid" styleClass="btn-cancel-auto-bid" text="Cancel Auto Bid"/>
                            </VBox>
                        </VBox>
                    </VBox>

                    <VBox styleClass="auction-info-card" spacing="15">
                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="history-title" text="History Bids"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox alignment="CENTER" spacing="5" styleClass="bid-count-badge">
                                <Label fx:id="totalBidsLabel" styleClass="total-bids-label" text="0 bids"/>
                            </HBox>
                        </HBox>

                        <ScrollPane fx:id="historyScrollPane" fitToWidth="true" fitToHeight="true" minHeight="300.0" prefHeight="300.0" maxHeight="300.0" styleClass="history-scroll-pane">
                            <VBox fx:id="historyBidContainer" spacing="12" styleClass="history-bid-container">
                                <padding>
                                    <Insets top="0" right="15" bottom="0" left="0"/>
                                </padding>
                            </VBox>
                        </ScrollPane>
                    </VBox>
                </VBox>
            </HBox>
        </ScrollPane>
    </VBox>
</StackPane>