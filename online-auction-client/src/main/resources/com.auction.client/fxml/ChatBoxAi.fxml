<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="chatWindowContainer"
      spacing="0"
      styleClass="chat-container"
      stylesheets="@../css/ChatBoxAi.css"
      fx:controller="com.auction.client.controller.common.ChatBoxAiController"
      xmlns:fx="http://javafx.com/fxml">

    <HBox styleClass="chat-header" alignment="CENTER_LEFT">
        <padding>
            <Insets left="15.0" right="10.0"/>
        </padding>
        <Label text="✦" style="-fx-text-fill: white; -fx-font-size: 18;"/>
        <Label text="Auction AI" styleClass="header-text" style="-fx-padding: 0 0 0 10;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="window-control-btn" onAction="#closeChatBox"/>
    </HBox>

    <ScrollPane fx:id="chatScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                styleClass="chat-scroll"
                hbarPolicy="NEVER"
                vbarPolicy="NEVER">
        <VBox fx:id="messageArea" styleClass="message-area">
        </VBox>
    </ScrollPane>

    <VBox styleClass="chat-footer" spacing="10">
        <FlowPane hgap="5" vgap="5">
            <Button text="Create an auction" styleClass="suggest-btn" onAction="#sendSuggest"/>
            <Button text="How to bid?" styleClass="suggest-btn" onAction="#sendSuggest"/>
        </FlowPane>
        <HBox spacing="8" alignment="BOTTOM_CENTER">
            <TextArea fx:id="txtMessage"
                      promptText="Type your message..."
                      styleClass="chat-input"
                      wrapText="true"
                      HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnSend" onAction="#sendMessage" defaultButton="true"
                    styleClass="send-btn" text="➔"/>
        </HBox>
    </VBox>
</VBox>