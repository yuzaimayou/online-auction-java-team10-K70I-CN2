<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" stylesheets="@../css/HomePage.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox styleClass="main-container">

            <VBox styleClass="header-section">
                <HBox styleClass="top-bar" alignment="CENTER_LEFT">
                    <HBox alignment="CENTER_LEFT" spacing="5" styleClass="logo-container">
                        <Label text="⚖" styleClass="logo-icon"/>
                        <Label text="AUCTION" styleClass="logo-text"/>
                    </HBox>

                    <Label text="Categories ˅" styleClass="categories-dropdown" />

                    <Region HBox.hgrow="ALWAYS" />

                    <HBox styleClass="search-bar" alignment="CENTER_LEFT">
                        <Label text="🔍" styleClass="search-icon"/>
                        <TextField promptText="Search for anything" styleClass="search-input" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <StackPane styleClass="profile-icon-container">
                            <Label text="👤" styleClass="profile-icon"/>
                        </StackPane>
                        <Label text="Van" styleClass="profile-name"/>
                    </HBox>
                </HBox>

                <HBox styleClass="nav-menu" alignment="CENTER">
                    <Label text="Home" styleClass="nav-item, nav-item-active" />
                    <Label text="About Us" styleClass="nav-item" />
                    <Label text="Browse Auction" styleClass="nav-item" />
                    <Label text="How It Works" styleClass="nav-item" />
                </HBox>
            </VBox>

            <VBox styleClass="categories-section" alignment="CENTER">
                <Label text="Explore Categories" styleClass="section-title"/>
                <HBox styleClass="categories-list" alignment="CENTER">
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="👜"/></StackPane><Label text="Fashion"/></VBox>
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="💻"/></StackPane><Label text="Electronics"/></VBox>
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="🏠"/></StackPane><Label text="Home &amp; Garden"/></VBox>
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="🖼️"/></StackPane><Label text="Art"/></VBox>
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="📚"/></StackPane><Label text="Books"/></VBox>
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="💎"/></StackPane><Label text="Jewelry"/></VBox>
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="⚽"/></StackPane><Label text="Sports"/></VBox>
                    <VBox styleClass="category-item"><StackPane styleClass="cat-icon-bg"><Label text="⭐"/></StackPane><Label text="My Collection"/></VBox>
                </HBox>
            </VBox>

            <VBox styleClass="auctions-section" alignment="CENTER" VBox.vgrow="ALWAYS">
                <Label text="Ongoing Auctions" styleClass="section-title, gray-title"/>

                <HBox styleClass="auctions-list" alignment="CENTER">
                    <VBox styleClass="auction-card">
                        <StackPane styleClass="card-image-placeholder">
                            <Label text="Image: iPhone 17" textFill="#999999"/>
                        </StackPane>
                        <VBox styleClass="card-content">
                            <Label text="IPhone 17 Pro Max 2025" styleClass="card-title"/>
                            <Label text="Auction is live" styleClass="live-badge"/>
                            <Label text="Ends at: 28/03/2026 18:00PM" styleClass="card-info"/>
                            <Label text="Starting Price: 20.000.000 VNĐ" styleClass="card-info"/>
                        </VBox>
                    </VBox>

                    <VBox styleClass="auction-card">
                        <StackPane styleClass="card-image-placeholder" style="-fx-background-color: #d1e7dd;">
                            <Label text="Image: Pokemon Card" textFill="#999999"/>
                        </StackPane>
                        <VBox styleClass="card-content">
                            <Label text="Rare Pokémon Trading Card" styleClass="card-title" wrapText="true"/>
                            <Label text="Auction is live" styleClass="live-badge"/>
                            <Label text="Ends at: 28/03/2026 18:00PM" styleClass="card-info"/>
                            <Label text="Starting Price: 20.000.000 VNĐ" styleClass="card-info"/>
                        </VBox>
                    </VBox>

                    <VBox styleClass="auction-card">
                        <StackPane styleClass="card-image-placeholder">
                            <Label text="Image: iPhone 17" textFill="#999999"/>
                        </StackPane>
                        <VBox styleClass="card-content">
                            <Label text="IPhone 17 Pro Max 2025" styleClass="card-title"/>
                            <Label text="Auction is live" styleClass="live-badge"/>
                            <Label text="Ends at: 28/03/2026 18:00PM" styleClass="card-info"/>
                            <Label text="Starting Price: 20.000.000 VNĐ" styleClass="card-info"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

        </VBox>
    </content>
</ScrollPane>